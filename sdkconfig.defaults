CONFIG_COMPILER_OPTIMIZATION_SIZE=y
# CONFIG_MESH_ENABLE_PS is not set
CONFIG_CHOINKA_V2_LOG_TUNNEL_ENABLE=y
# CONFIG_KEEMASH_V2_COMPAT_TUNNEL_ENABLE is not set
CONFIG_CHOINKA_MESH_RELAY_ELIGIBLE=y
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
CONFIG_CHOINKA_PSRAM_EXPECTED_BYTES=0
CONFIG_CHOINKA_PUMP_ACTIVE_HIGH=y
CONFIG_CHOINKA_PUMP_BOOT_PULSE_ENABLE=y
CONFIG_CHOINKA_PUMP_BOOT_PULSE_MS=200
CONFIG_CHOINKA_PUMP_CHECK_PERIOD_MS=1000
CONFIG_CHOINKA_PUMP_MAX_RUN_MS=3000
CONFIG_CHOINKA_PUMP_MIN_PAUSE_MS=60000
CONFIG_CHOINKA_LEVEL_DRY_THRESHOLD_MV=1100
CONFIG_CHOINKA_LEVEL_WET_THRESHOLD_MV=1900
CONFIG_CHOINKA_LEVEL_DRY_CONFIRM_CYCLES=3
CONFIG_CHOINKA_LEVEL_WET_CONFIRM_CYCLES=2
CONFIG_SPIRAM=y
CONFIG_SPIRAM_TYPE_AUTO=y
CONFIG_SPIRAM_SPEED_40M=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_RUN_TIME_STATS_USING_ESP_TIMER=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
